<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>웹 접근성 검사 리포트</title>
  <style>
    :root {
      --color-critical: #d93025;
      --color-serious: #f29900;
      --color-moderate: #fbbc04;
      --color-minor: #1a73e8;
      --color-bg-light: #f8f9fa;
      --color-border: #dadce0;
      --color-text: #202124;
      --color-text-secondary: #5f6368;
      --color-code-bg: #e8eaed;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      color: var(--color-text);
      margin: 0;
      background-color: #fff;
    }
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 2rem;
    }
    header {
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 1.5rem;
      margin-bottom: 2rem;
    }
    h1 {
      font-size: 2rem;
      margin: 0;
    }
    .summary {
      display: flex;
      gap: 2rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }
    .summary-item {
      text-align: center;
    }
    .summary-item .count {
      font-size: 2.5rem;
      font-weight: 600;
      display: block;
    }
    .summary-item .label {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      text-transform: uppercase;
    }
    .count.violations { color: var(--color-critical); }
    .count.passes { color: #34a853; }
    .count.incomplete { color: var(--color-serious); }
    .count.inapplicable { color: var(--color-text-secondary); }
    .metadata {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      margin-top: 0.5rem;
    }
    .metadata a {
      color: var(--color-minor);
      text-decoration: none;
      word-break: break-all;
    }
    .metadata a:hover {
      text-decoration: underline;
    }
    h2 {
      font-size: 1.5rem;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0.5rem;
      margin-top: 3rem;
    }
    .violation-card {
      border: 1px solid var(--color-border);
      border-radius: 8px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .violation-header {
      padding: 1rem 1.5rem;
      background-color: var(--color-bg-light);
      border-bottom: 1px solid var(--color-border);
    }
    .violation-header h3 {
      margin: 0;
      font-size: 1.2rem;
    }
    .impact {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 1rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: #fff;
      margin-right: 0.5rem;
      text-transform: capitalize;
    }
    .impact.critical { background-color: var(--color-critical); }
    .impact.serious { background-color: var(--color-serious); }
    .impact.moderate { background-color: var(--color-moderate); }
    .impact.minor { background-color: var(--color-minor); }
    .violation-body {
      padding: 1.5rem;
    }
    .violation-body p {
      margin: 0 0 1rem 0;
    }
    .node-list {
      margin-top: 1.5rem;
    }
    .node-item {
      border-top: 1px dashed var(--color-border);
      padding-top: 1rem;
      margin-top: 1rem;
    }
    .node-item:first-child {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }
    code, pre {
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, Courier, monospace;
      background-color: var(--color-code-bg);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      font-size: 90%;
    }
    pre {
      padding: 1em;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
    .tags {
      margin-top: 0.5rem;
    }
    .tag {
      display: inline-block;
      background-color: var(--color-code-bg);
      color: var(--color-text-secondary);
      padding: 0.2rem 0.6rem;
      border-radius: 3px;
      font-size: 0.8rem;
      margin-right: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>웹 접근성 검사 리포트</h1>
      <p class="metadata">
        <strong>검사 대상 URL:</strong> <a href="<%= url %>" target="_blank"><%= url %></a><br>
        <strong>검사 시간:</strong> <%= timestamp %>
      </p>
      <div class="summary">
        <div class="summary-item">
          <span class="count violations"><%= violations.length %></span>
          <span class="label">위반</span>
        </div>
        <div class="summary-item">
          <span class="count passes"><%= passes.length %></span>
          <span class="label">통과</span>
        </div>
        <div class="summary-item">
          <span class="count incomplete"><%= incomplete.length %></span>
          <span class="label">확인 필요</span>
        </div>
        <div class="summary-item">
          <span class="count inapplicable"><%= inapplicable.length %></span>
          <span class="label">해당 없음</span>
        </div>
      </div>
    </header>

    <main>
      <h2>위반 항목 (<%= violations.length %>)</h2>

      <% if (violations.length === 0) { %>
        <p>🎉 위반 사항이 발견되지 않았습니다!</p>
      <% } else { %>
        <% violations.forEach((violation, index) => { %>
          <div class="violation-card">
            <div class="violation-header">
              <h3>
                <span class="impact <%= violation.impact %>"><%= violation.impact %></span>
                <%= violation.help %>
              </h3>
              <div class="tags">
                <% violation.tags.forEach(tag => { %>
                  <span class="tag"><%= tag %></span>
                <% }); %>
              </div>
            </div>
            <div class="violation-body">
              <p><%= violation.description %></p>
              <p><strong>도움말:</strong> <a href="<%= violation.helpUrl %>" target="_blank"><%= violation.helpUrl %></a></p>
              
              <h4>영향 받는 요소 (<%= violation.nodes.length %>개)</h4>
              <div class="node-list">
                <% violation.nodes.forEach(node => { %>
                  <div class="node-item">
                    <p><strong>요소 선택자:</strong> <code><%= node.target.join(', ') %></code></p>
                    <p><strong>HTML:</strong></p>
                    <pre><code><%= node.html %></code></pre>
                    <p><strong>해결 방법:</strong></p>
                    <pre><%= node.failureSummary %></pre>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </main>
  </div>
</body>
</html>